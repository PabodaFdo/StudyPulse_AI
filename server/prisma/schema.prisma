datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                      Int                      @id @default(autoincrement())
  email                   String                   @unique
  password                String
  name                    String
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  subjects                Subject[]
  notes                   Note[]
  focusSessions           FocusSession[]
  academicRecords         AcademicRecord[]
  studyGarden             StudyGarden?
  growthActivities        GrowthActivity[]
  quests                  StudyQuest[]
  savedSummaries          SavedSummary[]
  savedQuizzes            SavedQuiz[]
  savedFlashcardDecks     SavedFlashcardDeck[]
  studyMaterials          StudyMaterial[]
  quizAttempts            QuizAttempt[]
  assessments             Assessment[]
  riskPredictionHistories RiskPredictionHistory[]
  flashcardReviewAttempts FlashcardReviewAttempt[]
  summaryReviewAttempts   SummaryReviewAttempt[]
  moodCheckIns            MoodCheckIn[]
  revisionReminders       RevisionReminder[]
}

model Subject {
  id                      Int                      @id @default(autoincrement())
  name                    String
  code                    String?
  credits                 Int?
  gradeTarget             String?
  currentStanding         String?
  status                  String?
  description             String?
  userId                  Int
  user                    User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  notes                   Note[]
  focusSessions           FocusSession[]
  academicRecords         AcademicRecord[]
  quizAttempts            QuizAttempt[]
  assessments             Assessment[]
  riskPredictionHistories RiskPredictionHistory[]
  flashcardReviewAttempts FlashcardReviewAttempt[]
  summaryReviewAttempts   SummaryReviewAttempt[]
  revisionReminders       RevisionReminder[]
}

model Note {
  id        Int      @id @default(autoincrement())
  title     String
  content   String   @db.Text
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjectId Int
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FocusSession {
  id        Int      @id @default(autoincrement())
  duration  Int // in minutes
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjectId Int
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AcademicRecord {
  id                   Int      @id @default(autoincrement())
  grade                String
  userId               Int
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjectId            Int
  subject              Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  courseCode           String?
  courseName           String?
  credits              Int?
  attendancePercentage Float?
  assignmentAverage    Float?
  quizAverage          Float?
  studyHoursPerWeek    Float?
  missedDeadlines      Int?
  previousExamMark     Float?
  examMark             Float?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model StudyGarden {
  id        Int      @id @default(autoincrement())
  level     Int      @default(1)
  userId    Int      @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GrowthActivity {
  id        Int      @id @default(autoincrement())
  activity  String
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StudyQuest {
  id           Int      @id @default(autoincrement())
  title        String
  description  String?
  type         String   @default("DAILY")
  targetCount  Int      @default(1)
  rewardPoints Int      @default(10)
  completed    Boolean  @default(false)
  userId       Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SavedSummary {
  id          String   @id @default(cuid())
  userId      Int
  title       String
  sourceType  String
  sourceTitle String?
  content     Json
  wordCount   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SavedQuiz {
  id          String   @id @default(cuid())
  userId      Int
  title       String
  sourceType  String
  sourceTitle String?
  questions   Json
  wordCount   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SavedFlashcardDeck {
  id          String   @id @default(cuid())
  userId      Int
  title       String
  sourceType  String
  sourceTitle String?
  flashcards  Json
  wordCount   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StudyMaterial {
  id            String   @id @default(cuid())
  userId        Int
  title         String
  fileName      String?
  sourceType    String   @default("pdf")
  extractedText String   @db.Text
  wordCount     Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model QuizAttempt {
  id             String   @id @default(cuid())
  userId         Int
  subjectId      Int?
  noteId         String?
  sourceType     String?
  sourceTitle    String?
  difficulty     String?
  score          Int
  totalQuestions Int
  percentage     Float
  wrongAnswers   Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)
}

model Assessment {
  id             String    @id @default(cuid())
  userId         Int
  subjectId      Int
  title          String
  type           String
  mark           Float
  weight         Float
  assessmentDate DateTime?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
}

model RiskPredictionHistory {
  id                     Int      @id @default(autoincrement())
  userId                 Int
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjectId              Int
  subject                Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  riskScore              Float
  riskLevel              String
  trend                  String
  trendMessage           String
  studyEngagement        Float
  assessmentAverage      Float
  quizAverage            Float
  studyHoursPerWeek      Float
  focusSessionsCompleted Int
  previousExamMark       Float
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model FlashcardReviewAttempt {
  id              Int      @id @default(autoincrement())
  userId          Int
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjectId       Int?
  subject         Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  flashcardDeckId String?
  sourceTitle     String?
  totalCards      Int
  reviewedCards   Int
  knownCards      Int
  needReviewCards Int
  accuracy        Float
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SummaryReviewAttempt {
  id                  Int      @id @default(autoincrement())
  userId              Int
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjectId           Int?
  subject             Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  summaryId           String?
  sourceTitle         String?
  summaryWordCount    Int
  readDurationSeconds Int
  completed           Boolean
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model MoodCheckIn {
  id          String   @id @default(cuid())
  userId      Int
  mood        Int
  moodLabel   String?
  energyLevel Int
  stressLevel Int
  journalNote String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model RevisionReminder {
  id          String    @id @default(cuid())
  userId      Int
  subjectId   Int?
  title       String
  description String?
  sourceType  String?
  sourceId    String?
  dueDate     DateTime?
  priority    String    @default("Medium")
  status      String    @default("Pending")
  snoozeUntil DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([subjectId])
  @@index([status])
  @@index([priority])
  @@index([dueDate])
}
