datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id               Int                @id @default(autoincrement())
  email            String             @unique
  password         String
  name             String
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  subjects         Subject[]
  notes            Note[]
  focusSessions    FocusSession[]
  academicRecords  AcademicRecord[]
  studyGarden      StudyGarden?
  growthActivities    GrowthActivity[]
  quests              StudyQuest[]
  savedSummaries      SavedSummary[]
  savedQuizzes        SavedQuiz[]
  savedFlashcardDecks SavedFlashcardDeck[]
  studyMaterials      StudyMaterial[]
  quizAttempts        QuizAttempt[]
  assessments         Assessment[]
}

model Subject {
  id              Int               @id @default(autoincrement())
  name            String
  code            String?
  credits         Int?
  gradeTarget     String?
  currentStanding String?
  status          String?
  description     String?
  userId          Int
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  notes           Note[]
  focusSessions   FocusSession[]
  academicRecords AcademicRecord[]
  quizAttempts    QuizAttempt[]
  assessments     Assessment[]
}

model Note {
  id        Int      @id @default(autoincrement())
  title     String
  content   String   @db.Text
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjectId Int
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FocusSession {
  id        Int      @id @default(autoincrement())
  duration  Int      // in minutes
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjectId Int
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AcademicRecord {
  id                   Int      @id @default(autoincrement())
  grade                String
  userId               Int
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjectId            Int
  subject              Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  courseCode           String?
  courseName           String?
  credits              Int?
  attendancePercentage Float?
  assignmentAverage    Float?
  quizAverage          Float?
  studyHoursPerWeek    Float?
  missedDeadlines      Int?
  previousExamMark     Float?
  examMark             Float?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model StudyGarden {
  id        Int      @id @default(autoincrement())
  level     Int      @default(1)
  userId    Int      @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GrowthActivity {
  id        Int      @id @default(autoincrement())
  activity  String
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StudyQuest {
  id           Int      @id @default(autoincrement())
  title        String
  description  String?
  type         String   @default("DAILY")
  targetCount  Int      @default(1)
  rewardPoints Int      @default(10)
  completed    Boolean  @default(false)
  userId       Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SavedSummary {
  id          String   @id @default(cuid())
  userId      Int
  title       String
  sourceType  String
  sourceTitle String?
  content     Json
  wordCount   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SavedQuiz {
  id          String   @id @default(cuid())
  userId      Int
  title       String
  sourceType  String
  sourceTitle String?
  questions   Json
  wordCount   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SavedFlashcardDeck {
  id          String   @id @default(cuid())
  userId      Int
  title       String
  sourceType  String
  sourceTitle String?
  flashcards  Json
  wordCount   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StudyMaterial {
  id            String   @id @default(cuid())
  userId        Int
  title         String
  fileName      String?
  sourceType    String   @default("pdf")
  extractedText String   @db.Text
  wordCount     Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model QuizAttempt {
  id             String   @id @default(cuid())
  userId         Int
  subjectId      Int?
  noteId         String?
  sourceType     String?
  sourceTitle    String?
  difficulty     String?
  score          Int
  totalQuestions Int
  percentage     Float
  wrongAnswers   Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject        Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)
}

model Assessment {
  id             String   @id @default(cuid())
  userId         Int
  subjectId      Int
  title          String
  type           String
  mark           Float
  weight         Float
  assessmentDate DateTime?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject        Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
}
